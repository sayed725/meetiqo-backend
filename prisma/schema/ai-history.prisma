model AIHistory {
  id          String        @id @default(cuid())
  userId      String
  featureType AIFeatureType
  input       Json
  output      Json
  tokensUsed  Int
  createdAt   DateTime      @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([featureType])
  @@index([createdAt])
}
