# === Backend Environment Variables ===
# Copy this file to .env and fill in your values

# Server
PORT=5001
NODE_ENV=development

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/meetiqo?sslmode=require

# Redis (Upstash Redis or Render Redis)
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# AI
GEMINI_API_KEY=

# Stripe (optional - only if using payments)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Email (optional - for transactional emails)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@meetiqo.com
